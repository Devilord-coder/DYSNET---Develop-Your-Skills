# Секретный ключ Flask
SECRET_KEY=secret_key

# Настройки базы данных
DATABASE_FILE="data/server.db"

# Настройки сервера
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=False

# Дополнительные настройки
PERMANENT_SESSION_LIFETIME_DAYS=30

# токен для скачивания файлов с Яндекс Диска
DISK_AUTH_TOKEN

# Настройки почты
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=dysnet@yandex.ru
MAIL_PASSWORD=...
MAIL_DEFAULT_SENDER=dysnet@yandex.ru
MAIL_ADMIN=dysnet@yandex.ru
